# ─── Telethon — חשבון משתמש ייעודי לפרסום ───────────────────────────────────
# קבל מ-https://my.telegram.org (Apps)
TELE_API_ID=
TELE_API_HASH=
TELE_PHONE=           # מספר בינלאומי: +972501234567

# ─── Admin — לפקודות ניהול דרך הבוט ─────────────────────────────────────────
BOT_TOKEN=8552909506:AAH3zZIyHnj9nriHxG_UOLmkkly_7kBrDqA
ADMIN_ID=8235527820

# ─── לימיטים יומיים ───────────────────────────────────────────────────────────
MAX_NEW_GROUPS_PER_DAY=5       # כמה קבוצות חדשות לגלות ביום
DAILY_POST_LIMIT=8             # מקסימום פוסטים ביום סה"כ
POST_COOLDOWN_DAYS=7           # ימי המתנה בין פוסטים לאותה קבוצה

# ─── תזמון (שעון ישראל) ───────────────────────────────────────────────────────
MIN_DELAY_MINUTES=25           # המתנה מינימלית בין פוסטים
MAX_DELAY_MINUTES=55           # המתנה מקסימלית בין פוסטים
ACTIVE_HOUR_START=10           # שעת התחלה
ACTIVE_HOUR_END=21             # שעת סיום

# ─── פילטר קבוצות ────────────────────────────────────────────────────────────
MIN_GROUP_MEMBERS=150          # מינימום חברים בקבוצה
MAX_GROUP_MEMBERS=50000        # מקסימום חברים בקבוצה

# ─── Instagram Agent ──────────────────────────────────────────────────────────
# ⚠️  הרצה ראשונה: instagrapi שולח checkpoint (אימות SMS/אימייל).
#     הרץ   python -m ig.main   פעם ראשונה ידנית — עקוב אחר ההוראות בטרמינל.
#     לאחר הצלחה נוצר ig_session.json — נשמר אוטומטית לכל הרצות הבאות.
IG_USERNAME=
IG_PASSWORD=
DAILY_IG_DM_LIMIT=15           # הודעות DM ביום (מומלץ להתחיל מ-10)
DAILY_IG_FOLLOW_LIMIT=20       # עקיבות ביום

# ─── Facebook Agent ───────────────────────────────────────────────────────────
# ⚠️  הרצה ראשונה: Playwright פותח דפדפן אמיתי — ייתכן שתצטרך לאשר 2FA ידנית.
#     לאחר ההתחברות נשמרים fb_cookies.json — בהרצות הבאות מתחבר אוטומטית.
#     אם נחסם: מחק fb_cookies.json והתחבר מחדש.
FB_EMAIL=
FB_PASSWORD=
DAILY_FB_POST_LIMIT=5          # פוסטים בקבוצות ביום
DAILY_FB_COMMENT_LIMIT=10      # תגובות ביום

# ─── TikTok Agent ─────────────────────────────────────────────────────────────
# ⚠️  הרצה ראשונה: TikTok דורש CAPTCHA — פתח Playwright ב-headful mode לפתרון ידני.
#     לאחר פתרון CAPTCHA נשמרים tt_cookies.json — בהרצות הבאות אוטומטי.
# ⚠️  TikTok מחמיר מאוד — הגדרות ברירת מחדל שמרניות.
#     אל תעלה לימיטים לפני שבוע–שבועיים של פעילות רגילה.
TT_USERNAME=
TT_PASSWORD=
DAILY_TT_COMMENT_LIMIT=23      # תגובות ביום (ברירת מחדל: 23)
DAILY_TT_FOLLOW_LIMIT=20       # עקיבות ביום (ברירת מחדל: 20)
